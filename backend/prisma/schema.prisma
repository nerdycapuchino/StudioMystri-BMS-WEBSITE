generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(uuid())
  name             String
  email            String         @unique
  passwordHash     String
  role             UserRole       @default(SALES)
  isActive         Boolean        @default(true)
  avatar           String?
  lastLogin        DateTime?
  refreshToken     String?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  activityLogs     ActivityLog[]
  employee         Employee?
  assignedLeads    Lead[]         @relation("AssignedLeads")
  messages         Message[]
  notifications    Notification[]
  assignedTasks    Task[]         @relation("AssignedTasks")
  referralsMade    Referral[]     @relation("ReferralsMade")
  referralsUsed    Referral[]     @relation("ReferralsUsed")
  orders           Order[]
  emailLogs        EmailLog[]

  @@map("users")
}

model Customer {
  id              String     @id @default(uuid())
  name            String
  email           String?
  phone           String?
  company         String?
  address         String?
  shippingAddress String?
  gstin           String?
  totalOrders     Int        @default(0)
  totalSpent      Float      @default(0)
  tags            String[]   @default([])
  notes           String?
  status          String     @default("Active")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  invoices        Invoice[]
  orders          Order[]
  projects        Project[]
  shipments       Shipment[]

  @@map("customers")
}

model Lead {
  id            String    @id @default(uuid())
  companyName   String
  pocName       String
  email         String?
  phone         String?
  website       String?
  gstin         String?
  stage         LeadStage @default(NEW)
  type          LeadType  @default(INBOUND)
  source        String?
  value         Float     @default(0)
  probability   Int?      @default(50)
  requirements  String?
  brief         String?
  notes         String?
  files         String[]  @default([])
  lastContact   DateTime?
  dateReceived  DateTime?
  expectedClose DateTime?
  assignedToId  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  assignedTo    User?     @relation("AssignedLeads", fields: [assignedToId], references: [id])

  @@map("leads")
}

model Product {
  id               String           @id @default(uuid())
  name             String
  slug             String?          @unique
  sku              String           @unique
  barcode          String?
  category         String
  price            Float
  cost             Float?
  stockQuantity    Int              @default(0)
  unit             String           @default("pcs")
  description      String?
  materials        String?
  dimensions       String?
  weight           Float?
  images           String[]         @default([])
  manualUrl        String?
  ecommerceVisible Boolean          @default(false)
  discountPrice    Float?
  seoTitle         String?
  seoDescription   String?
  ogImage          String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  variants         ProductVariant[]
  orderItems       OrderItem[]

  @@map("products")
}

model ProductVariant {
  id         String   @id @default(uuid())
  name       String
  sku        String   @unique
  price      Float
  stock      Int      @default(0)
  attributes Json?
  productId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model Order {
  id                 String        @id @default(uuid())
  orderNumber        String        @unique
  userId             String?
  subtotal           Float
  taxAmount          Float         @default(0)
  discountAmount     Float         @default(0)
  shippingAmount     Float         @default(0)
  totalAmount        Float
  paymentStatus      PaymentStatus @default(PENDING)
  orderStatus        OrderStatus   @default(CREATED)
  paymentGateway     String?
  paymentReferenceId String?
  paymentMethod      String?
  currency           String        @default("INR")
  notes              String?
  shippingAddress    Json?
  customerId         String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  customer             Customer?            @relation(fields: [customerId], references: [id])
  user                 User?                @relation(fields: [userId], references: [id])
  invoice              Invoice?
  
  items                OrderItem[]
  shippingInfo         ShippingInfo?
  paymentTransactions  PaymentTransaction[]
  emailLogs            EmailLog[]
  referrals            Referral[]

  @@map("orders")
}

model Invoice {
  id              String          @id @default(uuid())
  invoiceNumber   String          @unique
  items           Json
  subtotal        Float
  taxAmount       Float           @default(0)
  taxRate         Float?
  total           Float
  paidAmount      Float           @default(0)
  status          InvoiceStatus   @default(DRAFT)
  type            TransactionType @default(INCOME)
  currency        String          @default("INR")
  dueDate         DateTime?
  notes           String?
  pdfUrl          String?
  gstDetails      Json?
  sellerName      String?
  sellerAddress   String?
  sellerGst       String?
  buyerAddress    String?
  shippingAddress String?
  paymentMode     String?
  referenceNo     String?
  referenceDate   DateTime?
  buyerOrderNo    String?
  dispatchDocNo   String?
  dispatchThrough String?
  destination     String?
  termsOfDelivery String?
  pan             String?
  declaration     String?
  jurisdiction    String?
  bankName        String?
  accountNo       String?
  ifsc            String?
  branch          String?
  deliveryType    String?
  deliveryCost    Float?
  customerId      String?
  orderId         String?         @unique
  paymentHistory  Json[]          @default([])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  customer        Customer?       @relation(fields: [customerId], references: [id])
  order           Order?          @relation(fields: [orderId], references: [id])
  transactions    Transaction[]

  @@map("invoices")
}

model Transaction {
  id          String          @id @default(uuid())
  type        TransactionType
  category    String
  amount      Float
  description String?
  reference   String?
  date        DateTime        @default(now())
  invoiceId   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  invoice     Invoice?        @relation(fields: [invoiceId], references: [id])

  @@map("transactions")
}

model InventoryItem {
  id             String                 @id @default(uuid())
  name           String
  sku            String?                @unique
  category       String?
  type           InventoryType          @default(RAW)
  quantity       Float                  @default(0)
  unit           String                 @default("pcs")
  reorderPoint   Float                  @default(0)
  cost           Float                  @default(0)
  location       String?
  batchNumber    String?
  expiryDate     DateTime?
  barcode        String?
  bom            Json?
  supplierId     String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  supplier       Supplier?              @relation(fields: [supplierId], references: [id])
  stockMovements InventoryTransaction[]

  @@map("inventory_items")
}

model InventoryTransaction {
  id        String        @id @default(uuid())
  type      String
  quantity  Float
  reason    String?
  reference String?
  itemId    String
  userId    String?
  createdAt DateTime      @default(now())
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("inventory_transactions")
}

model Supplier {
  id            String          @id @default(uuid())
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  gstin         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         InventoryItem[]

  @@map("suppliers")
}

model Project {
  id              String       @id @default(uuid())
  name            String
  description     String?
  dimensions      String?
  siteAddress     String?
  stage           ProjectStage @default(CONCEPT)
  stages          String[]     @default(["Concept", "Design", "Material Procurement", "Execution", "Handover"])
  currentStage    String?
  progress        Int          @default(0)
  budget          Float        @default(0)
  spent           Float        @default(0)
  startDate       DateTime?
  endDate         DateTime?
  files           String[]     @default([])
  referenceImages String[]     @default([])
  customerId      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  payments        Payment[]
  customer        Customer?    @relation(fields: [customerId], references: [id])
  tasks           Task[]

  @@map("projects")
}

model Payment {
  id        String        @id @default(uuid())
  amount    Float
  method    PaymentMethod @default(BANK_TRANSFER)
  status    PaymentStatus @default(COMPLETED)
  note      String?
  date      DateTime      @default(now())
  projectId String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Employee {
  id                String         @id @default(uuid())
  name              String
  email             String
  phone             String?
  role              String?
  department        String?
  salary            Float          @default(0)
  joinDate          DateTime?
  status            EmployeeStatus @default(ACTIVE)
  dob               DateTime?
  currentAddress    String?
  permanentAddress  String?
  bloodGroup        String?
  emergencyContact  String?
  idProof           String?
  qualifications    String?
  notes             String?
  documents         String[]       @default([])
  leavePolicy       Int            @default(24)
  leavesRemaining   Int            @default(24)
  userId            String?        @unique
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  attendanceRecords Attendance[]
  user              User?          @relation(fields: [userId], references: [id])

  @@map("employees")
}

model Attendance {
  id         String           @id @default(uuid())
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus @default(PRESENT)
  employeeId String
  createdAt  DateTime         @default(now())
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, date])
  @@map("attendance")
}

model Shipment {
  id                String         @id @default(uuid())
  orderId           String?
  origin            String?
  destination       String?
  carrier           String?
  trackingNumber    String?
  trackingUrl       String?
  status            ShipmentStatus @default(PENDING)
  estimatedDelivery DateTime?
  items             Json?
  customerId        String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  customer          Customer?      @relation(fields: [customerId], references: [id])

  @@map("shipments")
}

model Task {
  id           String       @id @default(uuid())
  title        String
  description  String?
  priority     TaskPriority @default(MEDIUM)
  status       TaskStatus   @default(TODO)
  dueDate      DateTime?
  assignedToId String?
  projectId    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  assignedTo   User?        @relation("AssignedTasks", fields: [assignedToId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])

  @@map("tasks")
}

model Message {
  id          String   @id @default(uuid())
  content     String
  channel     String   @default("general")
  attachments String[] @default([])
  senderId    String
  createdAt   DateTime @default(now())
  sender      User     @relation(fields: [senderId], references: [id])

  @@map("messages")
}

model ActivityLog {
  id         String   @id @default(uuid())
  module     String
  action     String
  entityId   String?
  entityType String?
  details    Json?
  ipAddress  String?
  userId     String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([module])
  @@index([userId])
  @@map("activity_logs")
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String?
  isRead    Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model CompanySettings {
  id         String   @id @default(uuid())
  name       String   @default("Studio Mystri")
  address    String?
  gstin      String?
  logoUrl    String?
  loginBgUrl String?
  email      String?
  phone      String?
  currency   String   @default("INR")
  bankName   String?
  accountNo  String?
  ifsc       String?
  branch     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("company_settings")
}

model Campaign {
  id             String   @id @default(uuid())
  name           String
  channel        String
  status         String   @default("Active")
  conversionRate Float    @default(0)
  audience       Json?
  content        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("campaigns")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  DESIGNER
  ARCHITECT
  SALES
  FINANCE
  HR
  CUSTOMER
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  NEGOTIATION
  WON
  LOST
}

enum LeadType {
  INBOUND
  OUTBOUND
  REFERRAL
}

enum ProjectStage {
  CONCEPT
  DESIGN
  APPROVAL
  PROCUREMENT
  CONSTRUCTION
  EXECUTION
  FINISHING
  HANDOVER
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum InventoryType {
  RAW
  FINISHED
  CONSUMABLE
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum EmployeeStatus {
  ACTIVE
  LEAVE
  TERMINATED
}

enum OrderStatus {
  CREATED
  PROCESSING
  SHIPPED
  DELIVERED
  PENDING
  CONFIRMED
  COMPLETED
  REFUNDED
  CANCELLED
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  productId  String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model ShippingInfo {
  id             String    @id @default(uuid())
  orderId        String    @unique
  courierName    String?
  trackingId     String?
  trackingUrl    String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("shipping_info")
}

model DiscountCode {
  id                String       @id @default(uuid())
  code              String       @unique
  type              DiscountType @default(FLAT)
  value             Float
  minOrderAmount    Float?
  maxDiscountAmount Float?
  usageLimit        Int?
  usedCount         Int          @default(0)
  perUserLimit      Int?
  expiryDate        DateTime?
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@map("discount_codes")
}

model Referral {
  id             String    @id @default(uuid())
  referrerUserId String
  referredUserId String
  referralCode   String
  orderId        String?
  rewardIssued   Boolean   @default(false)
  rewardType     String?
  rewardValue    Float?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  referrer       User      @relation("ReferralsMade", fields: [referrerUserId], references: [id])
  referred       User      @relation("ReferralsUsed", fields: [referredUserId], references: [id])
  order          Order?    @relation(fields: [orderId], references: [id])

  @@map("referrals")
}

model PaymentTransaction {
  id                 String   @id @default(uuid())
  orderId            String
  gateway            String
  gatewayOrderId     String?
  gatewayPaymentId   String?
  amount             Float
  status             String
  signatureVerified  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payment_transactions")
}

model EmailLog {
  id        String   @id @default(uuid())
  emailType String
  userId    String?
  orderId   String?
  status    String
  sentAt    DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
  order     Order?   @relation(fields: [orderId], references: [id])

  @@map("email_logs")
}

enum DiscountType {
  FLAT
  PERCENT
}
