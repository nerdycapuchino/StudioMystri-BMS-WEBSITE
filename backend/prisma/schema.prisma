// ─── Prisma Schema for Studio Mystri BMS ───────────────────
// Run: npx prisma generate
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════

enum UserRole {
  ADMIN
  SALES
  HR
  FINANCE
  MANAGER
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  NEGOTIATION
  WON
  LOST
}

enum LeadType {
  INBOUND
  OUTBOUND
  REFERRAL
}

enum ProjectStage {
  CONCEPT
  DESIGN
  APPROVAL
  PROCUREMENT
  CONSTRUCTION
  EXECUTION
  FINISHING
  HANDOVER
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  CHEQUE
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum InventoryType {
  RAW
  FINISHED
  CONSUMABLE
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum EmployeeStatus {
  ACTIVE
  LEAVE
  TERMINATED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  COMPLETED
  REFUNDED
  CANCELLED
}

// ═══════════════════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════════════════

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          UserRole  @default(SALES)
  isActive      Boolean   @default(true)
  avatar        String?
  lastLogin     DateTime?
  refreshToken  String?

  // Relations
  employee      Employee?
  assignedLeads Lead[]     @relation("AssignedLeads")
  assignedTasks Task[]     @relation("AssignedTasks")
  activityLogs  ActivityLog[]
  messages      Message[]
  notifications Notification[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model Customer {
  id            String    @id @default(uuid())
  name          String
  email         String?
  phone         String?
  company       String?
  address       String?
  shippingAddress String?
  gstin         String?
  totalOrders   Int       @default(0)
  totalSpent    Float     @default(0)
  tags          String[]  @default([])
  notes         String?
  status        String    @default("Active")

  // Relations
  invoices      Invoice[]
  projects      Project[]
  shipments     Shipment[]
  orders        Order[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("customers")
}

model Lead {
  id            String     @id @default(uuid())
  companyName   String
  pocName       String
  email         String?
  phone         String?
  website       String?
  gstin         String?
  stage         LeadStage  @default(NEW)
  type          LeadType   @default(INBOUND)
  source        String?
  value         Float      @default(0)
  probability   Int?       @default(50)
  requirements  String?
  brief         String?
  notes         String?
  files         String[]   @default([])
  lastContact   DateTime?
  dateReceived  DateTime?
  expectedClose DateTime?

  // Relations
  assignedToId  String?
  assignedTo    User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("leads")
}

model Product {
  id            String    @id @default(uuid())
  name          String
  sku           String    @unique
  barcode       String?
  category      String
  price         Float
  cost          Float?
  stock         Int       @default(0)
  unit          String    @default("pcs")
  description   String?
  materials     String?
  dimensions    String?
  images        String[]  @default([])
  manualUrl     String?

  // Relations
  variants      ProductVariant[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("products")
}

model ProductVariant {
  id            String    @id @default(uuid())
  name          String
  sku           String    @unique
  price         Float
  stock         Int       @default(0)
  attributes    Json?

  // Relations
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("product_variants")
}

model Order {
  id            String      @id @default(uuid())
  orderNumber   String      @unique
  items         Json
  subtotal      Float
  taxAmount     Float       @default(0)
  discount      Float       @default(0)
  total         Float
  status        OrderStatus @default(COMPLETED)
  paymentMethod String?
  currency      String      @default("INR")
  notes         String?

  // Relations
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  invoice       Invoice?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("orders")
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  items           Json
  subtotal        Float
  taxAmount       Float         @default(0)
  taxRate         Float?
  total           Float
  paidAmount      Float         @default(0)
  status          InvoiceStatus @default(DRAFT)
  type            TransactionType @default(INCOME)
  currency        String        @default("INR")
  dueDate         DateTime?
  notes           String?
  pdfUrl          String?
  gstDetails      Json?

  // Seller/Buyer details snapshot
  sellerName      String?
  sellerAddress   String?
  sellerGst       String?
  buyerAddress    String?
  shippingAddress String?
  paymentMode     String?
  referenceNo     String?
  referenceDate   DateTime?
  buyerOrderNo    String?
  dispatchDocNo   String?
  dispatchThrough String?
  destination     String?
  termsOfDelivery String?
  pan             String?
  declaration     String?
  jurisdiction    String?

  // Bank details snapshot
  bankName        String?
  accountNo       String?
  ifsc            String?
  branch          String?

  // Delivery
  deliveryType    String?
  deliveryCost    Float?

  // Relations
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  orderId         String?       @unique
  order           Order?        @relation(fields: [orderId], references: [id])
  transactions    Transaction[]
  paymentHistory  Json[]        @default([])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("invoices")
}

model Transaction {
  id            String          @id @default(uuid())
  type          TransactionType
  category      String
  amount        Float
  description   String?
  reference     String?
  date          DateTime        @default(now())

  // Relations
  invoiceId     String?
  invoice       Invoice?        @relation(fields: [invoiceId], references: [id])

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("transactions")
}

model InventoryItem {
  id            String        @id @default(uuid())
  name          String
  sku           String?       @unique
  category      String?
  type          InventoryType @default(RAW)
  quantity      Float         @default(0)
  unit          String        @default("pcs")
  reorderPoint  Float         @default(0)
  cost          Float         @default(0)
  location      String?
  batchNumber   String?
  expiryDate    DateTime?
  barcode       String?
  bom           Json?

  // Relations
  supplierId    String?
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])
  stockMovements InventoryTransaction[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("inventory_items")
}

model InventoryTransaction {
  id            String    @id @default(uuid())
  type          String    // IN, OUT, ADJUSTMENT
  quantity      Float
  reason        String?
  reference     String?

  // Relations
  itemId        String
  item          InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId        String?

  createdAt     DateTime  @default(now())

  @@map("inventory_transactions")
}

model Supplier {
  id            String    @id @default(uuid())
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  gstin         String?

  // Relations
  items         InventoryItem[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("suppliers")
}

model Project {
  id              String       @id @default(uuid())
  name            String
  description     String?
  dimensions      String?
  siteAddress     String?
  stage           ProjectStage @default(CONCEPT)
  stages          String[]     @default(["Concept", "Design", "Material Procurement", "Execution", "Handover"])
  currentStage    String?
  progress        Int          @default(0)
  budget          Float        @default(0)
  spent           Float        @default(0)
  startDate       DateTime?
  endDate         DateTime?
  files           String[]     @default([])
  referenceImages String[]     @default([])

  // Relations
  customerId      String?
  customer        Customer?    @relation(fields: [customerId], references: [id])
  payments        Payment[]
  tasks           Task[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@map("projects")
}

model Payment {
  id            String        @id @default(uuid())
  amount        Float
  method        PaymentMethod @default(BANK_TRANSFER)
  status        PaymentStatus @default(COMPLETED)
  note          String?
  date          DateTime      @default(now())

  // Relations
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}

model Employee {
  id              String         @id @default(uuid())
  name            String
  email           String
  phone           String?
  role            String?
  department      String?
  salary          Float          @default(0)
  joinDate        DateTime?
  status          EmployeeStatus @default(ACTIVE)
  dob             DateTime?
  currentAddress  String?
  permanentAddress String?
  bloodGroup      String?
  emergencyContact String?
  idProof         String?
  qualifications  String?
  notes           String?
  documents       String[]       @default([])
  leavePolicy     Int            @default(24)
  leavesRemaining Int            @default(24)

  // Linked user account
  userId          String?        @unique
  user            User?          @relation(fields: [userId], references: [id])

  // Relations
  attendanceRecords Attendance[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("employees")
}

model Attendance {
  id            String           @id @default(uuid())
  date          DateTime
  checkIn       DateTime?
  checkOut      DateTime?
  status        AttendanceStatus @default(PRESENT)

  // Relations
  employeeId    String
  employee      Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt     DateTime         @default(now())

  @@index([employeeId, date])
  @@map("attendance")
}

model Shipment {
  id                String         @id @default(uuid())
  orderId           String?
  origin            String?
  destination       String?
  carrier           String?
  trackingNumber    String?
  trackingUrl       String?
  status            ShipmentStatus @default(PENDING)
  estimatedDelivery DateTime?
  items             Json?

  // Relations
  customerId        String?
  customer          Customer?      @relation(fields: [customerId], references: [id])

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("shipments")
}

model Task {
  id            String       @id @default(uuid())
  title         String
  description   String?
  priority      TaskPriority @default(MEDIUM)
  status        TaskStatus   @default(TODO)
  dueDate       DateTime?

  // Relations
  assignedToId  String?
  assignedTo    User?        @relation("AssignedTasks", fields: [assignedToId], references: [id])
  projectId     String?
  project       Project?     @relation(fields: [projectId], references: [id])

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("tasks")
}

model Message {
  id            String    @id @default(uuid())
  content       String
  channel       String    @default("general")
  attachments   String[]  @default([])

  // Relations
  senderId      String
  sender        User      @relation(fields: [senderId], references: [id])

  createdAt     DateTime  @default(now())

  @@map("messages")
}

model ActivityLog {
  id            String    @id @default(uuid())
  module        String
  action        String
  entityId      String?
  entityType    String?
  details       Json?
  ipAddress     String?

  // Relations
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])

  createdAt     DateTime  @default(now())

  @@index([module])
  @@index([userId])
  @@map("activity_logs")
}

model Notification {
  id            String    @id @default(uuid())
  title         String
  message       String
  type          String?
  isRead        Boolean   @default(false)

  // Relations
  userId        String
  user          User      @relation(fields: [userId], references: [id])

  createdAt     DateTime  @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model CompanySettings {
  id            String    @id @default(uuid())
  name          String    @default("Studio Mystri")
  address       String?
  gstin         String?
  logoUrl       String?
  loginBgUrl    String?
  email         String?
  phone         String?
  currency      String    @default("INR")
  bankName      String?
  accountNo     String?
  ifsc          String?
  branch        String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("company_settings")
}

model Campaign {
  id              String    @id @default(uuid())
  name            String
  channel         String
  status          String    @default("Active")
  conversionRate  Float     @default(0)
  audience        Json?
  content         String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("campaigns")
}
