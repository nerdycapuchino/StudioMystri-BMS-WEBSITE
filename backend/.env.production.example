# Copy to backend/.env on the VPS — NEVER commit the real .env

NODE_ENV=production
PORT=5000
CORS_ORIGIN=https://YOUR_DOMAIN

# PostgreSQL — use the credentials from setup-vps.sh
DATABASE_URL=postgresql://studiomystri_user:YOUR_DB_PASSWORD@localhost:5432/studiomystri

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=GENERATE_64_CHAR_HEX_STRING_HERE
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_64_CHAR_HEX_STRING_HERE

# File uploads
UPLOAD_DIR=/var/www/studiomystri/backend/uploads
MAX_FILE_SIZE_MB=10

# Email (optional — for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
