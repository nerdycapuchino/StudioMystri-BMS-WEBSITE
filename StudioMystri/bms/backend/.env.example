# Studio Mystri BMS — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/studiomystri?schema=public

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string

# Server
PORT=5000
NODE_ENV=production
CORS_ORIGIN=https://your-domain.com

# Sentry (optional)
SENTRY_DSN=

# File Uploads
UPLOAD_DIR=./uploads
